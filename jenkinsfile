pipeline {
    agent any

    environment {
        // 改為 AWS 帳號 ID 與區域
        ACCOUNT_ID     = "${env.AWS_ACCOUNT_ID}"
        AWS_REGION     = "${env.AWS_DEFAULT_REGION}"
        ECR_URL        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        GIT_URL        = "https://github.com/king610160/ecommerce_microservice.git"
        PROJECT_PREFIX = "prod-ecommerce"

        // short hash
        GIT_SHORT_HASH = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
    }

    stages {
        stage('Checkout') {
            steps {
                // 使用設定好的 Credentials
                checkout([$class: 'GitSCM', 
                    branches: [[name: '*/main']], 
                    userRemoteConfigs: [[url: "${GIT_URL}", 
                    credentialsId: 'jenkins_microservice']],
                    Gemini 說了
在你的腳本中，[skip ci] 出現在 Stage 'Build & Push Auth Service' 的最後一個 sh 指令裡：

Groovy
git commit -m "chore(deploy): update auth-service image tag to ${tag} [skip ci]" || echo "No changes"
雖然你已經在 Commit Message 裡寫了這串字，但 Jenkins 預設是不會理會它的。它只是一串普通的文字，除非你額外告訴 Jenkins：「看到這串字請不要觸發 Build」。

為了徹底解決這個「無限循環」並優化你提到的「三個服務都要做重複動作」的問題，我建議進行以下調整：

1. 讓 Jenkins 認得 [skip ci]
你需要安裝 Git Plugin（通常內建已裝），並在 Pipeline 腳本中加入 extensions。

修改 Checkout 階段，加入 PollSkipRegionConsole 或是排除特定的 Commit 訊息：

Groovy
stage('Checkout') {
    steps {
        checkout([$class: 'GitSCM', 
                branches: [[name: '*/main']], 
                userRemoteConfigs: [[url: "${GIT_URL}", credentialsId: 'jenkins_microservice']],
                extensions: [[$class: 'MessageExclusion', excludedMessage: '.*\\[skip ci\\].*']]        
            ]),    
            }
        }

        stage('Login to ECR') {
            steps {
                script {
                    // 有綁 IAM Role，可直接執行不需要帶 Key
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_URL}"
                }
            }
        }

        // --- 以下為各別服務的打包階段 ---
        stage('Build & Push Auth Service') {
            when { changeset "services/auth-service/**" }
            steps {
                script {
                    def imageName = "${ECR_URL}/${PROJECT_PREFIX}/auth-service"
                    def tag = "v${env.BUILD_NUMBER}-${GIT_SHORT_HASH}"
                    sh "docker build -t ${imageName}:${tag} ./services/auth-service"
                    sh "docker push ${imageName}:${tag}"
                    sh "docker tag ${imageName}:${tag} ${imageName}:latest"
                    sh "docker push ${imageName}:latest"

                    sh "docker rmi ${imageName}:${tag} ${imageName}:latest"

                    // 2. 更新 Helm 的 values.yaml (只改 tag，不碰 Registry)
                    // 使用 sed 修改 deploy 目錄下的 values.yaml
                    dir("deploy/auth-service") {
                        sh "sed -i 's/tag: .*/tag: \"${tag}\"/' values.yaml"
                    }

                    // 3. 使用憑證推回 Git (注入認證資訊以解決 fatal error)
                    withCredentials([usernamePassword(credentialsId: '334dca78-967e-4cae-bd9a-0d0c81ffc23b', 
                                     passwordVariable: 'GIT_PASS', 
                                     usernameVariable: 'GIT_USER')]) {
                        sh """
                            git remote set-url origin https://${GIT_USER}:${GIT_PASS}@github.com/king610160/ecommerce_microservice.git
                            
                            git config user.email "jenkins@example.com"
                            git config user.name "Jenkins CI"
                            git add deploy/auth-service/values.yaml
                            git commit -m "chore(deploy): update auth-service image tag to ${tag} [skip ci]" || echo "No changes"
                            git push origin HEAD:main
                        """
                    }
                }
            }
        }

        stage('Build & Push Order Service') {
            when { changeset "services/order-service/**" }
            steps {
                script {
                    def imageName = "${ECR_URL}/${PROJECT_PREFIX}/order-service"
                    def tag = "v${env.BUILD_NUMBER}-${GIT_SHORT_HASH}"
                    sh "docker build -t ${imageName}:${tag} ./services/order-service"
                    sh "docker push ${imageName}:${tag}"
                    sh "docker tag ${imageName}:${tag} ${imageName}:latest"
                    sh "docker push ${imageName}:latest"

                    sh "docker rmi ${imageName}:${tag} ${imageName}:latest"

                                        // 2. 更新 Helm 的 values.yaml (只改 tag，不碰 Registry)
                    // 使用 sed 修改 deploy 目錄下的 values.yaml
                    dir("deploy/order-service") {
                        sh "sed -i 's/tag: .*/tag: \"${tag}\"/' values.yaml"
                    }

                    // 3. 使用憑證推回 Git (注入認證資訊以解決 fatal error)
                    withCredentials([usernamePassword(credentialsId: '334dca78-967e-4cae-bd9a-0d0c81ffc23b', 
                                     passwordVariable: 'GIT_PASS', 
                                     usernameVariable: 'GIT_USER')]) {
                        sh """
                            git remote set-url origin https://${GIT_USER}:${GIT_PASS}@github.com/king610160/ecommerce_microservice.git
                            
                            git config user.email "jenkins@example.com"
                            git config user.name "Jenkins CI"
                            git add deploy/order-service/values.yaml
                            git commit -m "chore(deploy): update order-service image tag to ${tag} [skip ci]" || echo "No changes"
                            git push origin HEAD:main
                        """
                    }
                }
            }
        }

        stage('Build & Push Frontend') {
            when { changeset "services/frontend/**" }
            steps {
                script {
                    def imageName = "${ECR_URL}/${PROJECT_PREFIX}/frontend"
                    def tag = "v${env.BUILD_NUMBER}-${GIT_SHORT_HASH}"
                    // 注意：前端打包時，Nginx 設定會透過 Volume 掛載，所以這裡只包靜態檔
                    sh "docker build -t ${imageName}:${tag} ./services/frontend"
                    sh "docker push ${imageName}:${tag}"
                    sh "docker tag ${imageName}:${tag} ${imageName}:latest"
                    sh "docker push ${imageName}:latest"

                    sh "docker rmi ${imageName}:${tag} ${imageName}:latest"
                }
            }
        }
    }

    post {
        always {
            // 清理本地 Image，避免 EC2 硬碟爆掉 (SRE 必備)
            sh "docker image prune -f"
        }
        success {
            echo "Successfully deployed all changed services!"
        }
    }
}